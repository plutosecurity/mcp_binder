{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/mcp-binder/target-profile.schema.json",
  "title": "MCP Binder Target Profile",
  "type": "object",
  "required": ["name", "targetName", "transport", "port", "path", "strategy", "impact", "tasks"],
  "additionalProperties": true,
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "targetName": { "type": "string", "minLength": 1 },
    "transport": { "type": "string", "enum": ["streamable", "streamable-control", "sse", "ws-control"] },
    "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
    "path": { "type": "string", "pattern": "^/" },
    "strategy": { "type": "string", "enum": ["fs", "ma", "rr", "rd"] },
    "pollMs": { "type": "integer", "minimum": 100 },
    "maxTries": { "type": "integer", "minimum": 1 },
    "exfil": { "type": "string" },
    "out": { "type": "string" },
    "impact": {
      "type": "object",
      "required": ["summary", "vulnerableCondition", "evidenceGoal"],
      "additionalProperties": true,
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "vulnerableCondition": { "type": "string", "minLength": 1 },
        "evidenceGoal": { "type": "string", "minLength": 1 }
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/task" }
    }
  },
  "$defs": {
    "task": {
      "type": "object",
      "required": ["name", "kind"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "enum": ["tools/list", "tools/call", "rpc"] },
        "tool": { "type": "string" },
        "args": { "type": "object" },
        "rpc": { "type": "object" }
      }
    }
  }
}
